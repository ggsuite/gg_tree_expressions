{
  "borderWidth": {
    "resultType": "number",
    "variants": [
      {
        "expression": "1.0"
      },
      {
        "selector": {
          "theme#id": "dark"
        },
        "expression": "2.0"
      },
      {
        "selector": {
          "theme#id": "dark",
          "#platform": "mobile"
        },
        "inputs": {
          "screenWidth": {
            "query": "screen#width",
            "default": 4.0
          }
        },
        "expression": "screenWidth < 400.0 ? 3.0 : 2.0",
        "description": "Thicker borders on small dark-mode screens."
      }
    ]
  },
  "gap": [
    {
      "expression": "8.0"
    }
  ],
  "decoration": {
    "optional": true,
    "variants": [
      {
        "selector": {
          "#style": "fancy"
        },
        "expression": "\"gold\""
      }
    ]
  }
}